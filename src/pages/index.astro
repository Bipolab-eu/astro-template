---
/* Home */

import DynamicZone from "../components/Blocks/DynamicZone.astro";
import Layout from "../layouts/Layout.astro";
import { fetchApi } from "../lib/strapi/fetchApi";

// Cambia por el documentId de la página que se quiera mostrar
const documentId = import.meta.env.DOCUMENT_ID || "rfp5n8wdxpbcsrfmfe7y21cj";
const DZ = import.meta.env.DYNAMIC_ZONE

const data = await fetchApi({
  apiRoute: `/api/pages/${documentId}`,
}) as any

if (!data) return Astro.redirect("/404")

const { seo, [DZ]:items } = data // cambiar blocks por el nombre de la zona dinámica que uses en strapi

---

<Layout seo={seo}>
  <DynamicZone blocks={items} />
</Layout>