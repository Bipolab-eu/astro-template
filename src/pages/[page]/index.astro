---
/* Pages */
import Layout from "../../layouts/Layout.astro";
import { fetchApi } from "../../lib/strapi/fetchApi";

const { page } = Astro.params;

const data = await fetchApi({
  apiRoute: "/api/pages",
  filters: {
    slug: {
      $eq: page,
    },
  },
  // populate: true, 
  // true para popular el contenido. Por defecto es false.
}) as any

if (!data[0]) return Astro.redirect("/404")
---

<Layout seo={data[0].seo} blocks={data[0].blocks} />