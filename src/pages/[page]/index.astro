---
/* Pages */

import DynamicZone from "../../components/Blocks/DynamicZone.astro";
import Layout from "../../layouts/Layout.astro";
import { fetchApi } from "../../lib/strapi/fetchApi";

const { page } = Astro.params;
const DZ = import.meta.env.DYNAMIC_ZONE

const data = await fetchApi({
  apiRoute: "/api/pages",
  filters: {
    slug: {
      $eq: page,
    },
  },
}) as any

if (!data[0]) return Astro.redirect("/404")

const { seo, [DZ]:items } = data[0] // cambiar blocks por el nombre de la zona dinámica que uses en strapi
---

<Layout seo={seo}>
  <DynamicZone blocks={items} />
</Layout>