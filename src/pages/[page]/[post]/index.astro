---
/* Post */
import Layout from "../../../layouts/Layout.astro";
import { fetchApi } from "../../../lib/strapi/fetchApi";

const { post } = Astro.params;

const data = await fetchApi({
  apiRoute: `/api/posts`,
  filters: {
    slug: {
      $eq: post,
    },
  },
  // populate: true,
  // true para popular el contenido. Por defecto es false.
}) as any

if (!data[0]) return Astro.redirect("/404")
---

<Layout seo={data[0].seo} sections={data[0].sections} />