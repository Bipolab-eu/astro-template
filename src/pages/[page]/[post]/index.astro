---
/* Post */

import DynamicZone from "../../../components/Blocks/DynamicZone.astro";
import Layout from "../../../layouts/Layout.astro";
import { fetchApi } from "../../../lib/strapi/fetchApi";

const { post } = Astro.params;

const data = await fetchApi({
  apiRoute: `/api/posts`,
  filters: {
    slug: {
      $eq: post,
    },
  },
}) as any

if (!data[0]) return Astro.redirect("/404")

const { seo, blocks:items } = data[0] // cambiar blocks por el nombre de la zona dinámica que uses en strapi
---

<Layout seo={seo}>
  <DynamicZone blocks={items} />
</Layout>