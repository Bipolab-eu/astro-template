---
import Hero from '../components/Sections/Hero.astro';

/* Para que esto funciona hay que crear una zona dinnamica en strapi 
que se llame blocks, en minúscula y plural 
*/

interface Props { blocks: any }

const { blocks } = Astro.props as Props;

const listComponents: Record<string, any> = {
 'blocks.hero': Hero,
 // add more components
};

if (!blocks) return console.warn("DynamicZone: No sections found")

---
{
  blocks.map((item: any, i: number) => {
    const Component = listComponents[item.__component];
    return <Component key={`${item.id || ""}-${i}`} {...item} />;
  })
}
