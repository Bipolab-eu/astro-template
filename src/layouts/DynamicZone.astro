---
/* Para que esto funciona hay que crear una zona dinnamica en strapi 
que se llame sections, en minúscula y plural 
*/
import Hero from "../components/Hero.astro";

interface Props {
  sections: any
}

const { sections } = Astro.props as Props;

const listComponents: Record<string, any> = {
 'sections.hero': Hero,
};

if (!sections) return console.warn("DynamicZone: No sections found")

---
{
  sections.map((section: any, i: number) => {
    const Component = listComponents[section.__component];
    return <Component key={`${section.id || ""}-${i}`} {...section} />;
  })
}
